@page
@model IndexModel

@if (TempData["SuccessMessage"] != null)
{
    <div style="
        color:#1b5e20;
        background:#c8e6c9;
        font-size:22px;
        padding:10px 16px;
        border-radius:12px;
        margin-bottom:15px;
        text-align:center;
    ">
        ✅ @TempData["SuccessMessage"]
    </div>
}

@functions {
    string MealText(MealType meal) => meal switch
    {
        
		MealType.Breakfast => "🌅 早餐",
        MealType.Lunch => "🍱 午餐",
        MealType.Dinner => "🍽️ 晚餐",
        MealType.MidnightSnack => "🌙 宵夜",
        _ => meal.ToString()

    };
}

<div style="
    border:2px solid #e0e0e0;
    border-radius:12px;
    padding:12px 16px;
    margin-bottom:20px;
    background:#fafafa;
">
    <div style="font-size:22px; color:#555; margin-bottom:8px;">
        今天：@Model.TodayText
    </div>

    <div style="
        font-size:20px;
        color:#2e7d32;
        display:flex;
        flex-wrap:wrap;
        gap:20px;
        align-items:center;
    ">
        <div>
            今日完成度：
            <strong>@Model.TodayMealCount / @Model.TotalMealCount</strong>
        </div>

        @if (Model.TodayFilledMeals.Any())
        {
            <div>
                已填：
                <strong>@string.Join("、", Model.TodayFilledMeals.Select(m => MealText(m)))</strong>
            </div>
        }
    </div>
</div>

<h1 style="font-size:36px;">今天吃什麼？</h1>

@{
    string breakfastClass = Model.Meal == MealType.Breakfast ? "meal-btn breakfast active" : "meal-btn breakfast";
    string lunchClass     = Model.Meal == MealType.Lunch     ? "meal-btn lunch active"     : "meal-btn lunch";
    string dinnerClass    = Model.Meal == MealType.Dinner    ? "meal-btn dinner active"    : "meal-btn dinner";
}

<form method="post">

	<h2 style="margin-top:20px;">選擇日期</h2>

	<input type="date"
		   name="SelectedDate"
		   value="@Model.SelectedDate.ToString("yyyy-MM-dd")"
		   max="@DateTime.Today.ToString("yyyy-MM-dd")"
		   style="font-size:20px; padding:6px;" />

	<h2 style="margin-top:20px;">選擇餐別（單選）</h2>

	<div style="font-size:22px; margin-bottom:20px;">
		@foreach (var meal in new[]
		{
			MealType.Breakfast,
			MealType.Lunch,
			MealType.Dinner,
			MealType.MidnightSnack
		})
		{
			<label style="display:block; margin-bottom:8px;
						  color:@(Model.TodayFilledMeals.Contains(meal) ? "#999" : "#000");">
				<input type="radio"
					   name="Meal"
					   value="@meal"
					   @(Model.TodayFilledMeals.Contains(meal) ? "disabled" : "")
					   style="transform:scale(1.4); margin-right:8px;" />
				@MealText(meal)
				@if (Model.TodayFilledMeals.Contains(meal))
				{
					<span>（已完成）</span>
				}
			</label>
		}
	</div>

	<hr />

	<h2 style="background:#ffe0b2; padding:8px;">
		主菜（只能選一樣）
	</h2>

	<div id="mainFoodWarning"
		 style="color:red; font-size:20px; margin-bottom:10px; display:none;">
		⚠ 請選擇一樣主菜
	</div>

	@foreach (var item in Model.MainFoods)
	{
		<label style="display:block; font-size:22px;">
			<input type="radio"
				   name="MainFoodId"
				   value="@item.Id" />
			@item.Name
		</label>
	}
	
	<br />

	<h2 style="background:#c8e6c9; padding:8px;">
		配菜（建議選 1～3 樣）
	</h2>

	<div style="font-size:18px; color:#388e3c; margin-bottom:8px;">
		🟢 小提醒：配菜選 1～3 樣即可
	</div>

	@foreach (var item in Model.SideFoods)
	{
		<label style="display:block; font-size:22px;">
			<input type="checkbox"
				   name="SideFoodIds"
				   value="@item.Id" />
			@item.Name
		</label>
	}
	
	<br />
	<button type="submit"
			style="font-size:24px;"
			onclick="return validateMainFood();">
		完成這一餐
	</button>
	
</form>


@if (Model.Result != null)
{
    <hr style="margin:30px 0;" />

    <div style="
        font-size:30px;
        padding:15px;
        border-radius:12px;
        background-color:@(
            Model.Meal == MealType.Breakfast ? "#e3f2fd" :
            Model.Meal == MealType.Lunch     ? "#e8f5e9" :
                                                "#fff3e0"
        );
    ">
        @(Model.Result == NutritionStatus.Safe
            ? "✅ 這一餐這樣吃很適合"
            : "⚠ 這一餐建議稍微調整一下")
    </div>
}

<script>
function validateMainFood() {
    const radios = document.getElementsByName("MainFoodId");
    let selected = false;

    for (let r of radios) {
        if (r.checked) {
            selected = true;
            break;
        }
    }

    const warning = document.getElementById("mainFoodWarning");

    if (!selected) {
        warning.style.display = "block";
        return false; // ❌ 阻止送出
    }

    warning.style.display = "none";
    return true; // ✅ 可以送出
}
</script>